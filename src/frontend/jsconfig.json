{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "baseUrl": "./",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ]
  },
  "include": [
    "src/**/*",
    "entries/**/*"
  ],
  "exclude": [
    ".git",
    ".npm",
    ".npm-tmp",
    "**/dist/*",
    "**/node_modules/*",
  ],
}
