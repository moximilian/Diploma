{
    "name": "frontend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "lint": "vue-cli-service lint",
        "serve": "vue-cli-service serve --port 81",
        "build": "vue-cli-service build --port 81",
        "proxy": "node tools/proxy/index.js"
    },
    "keywords": [],
    "author": "Maxim Syrov",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "babel-plugin-transform-require-context": "^0.1.1",
        "core-js": "^3.8.3",
        "cors": "^2.8.5",
        "cross-fetch": "^3.1.5",
        "crypto-js": "^4.1.1",
        "date-fns": "^2.29.3",
        "jwt-decode": "^4.0.0",
        "mitt": "^3.0.0",
        "node-scp": "^0.0.23",
        "readline-sync": "^1.4.10",
        "vue": "^3.5.13",
        "vue-i18n": "^10.0.5",
        "vue-router": "^4.5.0",
        "vuex": "^4.1.0"
    },
    "devDependencies": {
        "@babel/core": "^7.12.16",
        "@babel/eslint-parser": "^7.12.16",
        "@babel/plugin-proposal-optional-chaining-assign": "^7.25.9",
        "@fortawesome/fontawesome-free": "^6.2.1",
        "@vue/cli-plugin-babel": "^5.0.8",
        "@vue/cli-plugin-eslint": "^5.0.8",
        "@vue/cli-plugin-router": "~5.0.0",
        "@vue/cli-plugin-unit-jest": "~5.0.0",
        "@vue/cli-service": "^5.0.8",
        "@vue/test-utils": "^2.0.0-rc.18",
        "@vue/vue3-jest": "^27.0.0-alpha.1",
        "babel-jest": "^27.0.6",
        "cypress": "^13.2.0",
        "eslint": "^7.32.0",
        "eslint-plugin-vue": "^8.0.3",
        "jest": "^27.0.5",
        "miragejs": "^0.1.47"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/vue3-essential",
            "eslint:recommended"
        ],
        "parserOptions": {
            "parser": "@babel/eslint-parser",
            "requireConfigFile": false,
            "babelOptions": {
                "plugins": [
                    [
                        "@babel/plugin-proposal-optional-chaining-assign",
                        {
                            "version": "2023-07"
                        }
                    ]
                ]
            }
        },
        "rules": {
            "no-control-regex": 0
        },
        "overrides": [
            {
                "files": [
                    "**/__tests__/*.{j,t}s?(x)",
                    "**/tests/unit/**/*.spec.{j,t}s?(x)"
                ],
                "env": {
                    "jest": true
                }
            }
        ]
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead",
        "not ie 11"
    ]
}